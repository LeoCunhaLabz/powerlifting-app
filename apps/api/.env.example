# Porta em que o servidor Fastify escuta
PORT=3000

# Interface de rede que o servidor usa (0.0.0.0 para containers)
HOST=0.0.0.0

# Origem permitida pelo CORS (URL do frontend)
CORS_ORIGIN=http://localhost:5173

# URL de conexão com o PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/powerlifting

# Segredo usado para assinar os JWT (HS256). Use uma string longa e aleatória (>= 32 caracteres)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-com-32-chars

# Tempo de expiração do access token (formato de tempo do @fastify/jwt, ex.: 15m, 1h)
JWT_EXPIRES_IN=15m

# Tempo de expiração do refresh token (ex.: 7d, 30d)
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Google OAuth ────────────────────────────────────────────────────────────────────────────

# Client ID do projeto no Google Cloud Console (APIs & Services → Credentials).
# Obrigatório para habilitar o endpoint POST /auth/google.
# Deixe vazio (ou omita) para desabilitar o login com Google na API.
GOOGLE_CLIENT_ID=
