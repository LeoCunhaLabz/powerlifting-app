{
  "name": "powerlifting-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @powerlifting/web",
    "build": "npm run build -w @powerlifting/web",
    "preview": "npm run preview -w @powerlifting/web",
    "lint": "npm run lint -w @powerlifting/web",
    "test": "npm run test -w @powerlifting/web",
    "generate-pwa-assets": "npm run generate-pwa-assets -w @powerlifting/web",
    "dev:api": "npm run dev -w @powerlifting/api",
    "build:api": "npm run build -w @powerlifting/api",
    "start:api": "npm run start -w @powerlifting/api",
    "lint:api": "npm run lint -w @powerlifting/api"
  }
}
