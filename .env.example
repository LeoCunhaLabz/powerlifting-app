# ─── Banco de dados ──────────────────────────────────────────────────────────
#
# Este arquivo serve ao docker-compose LOCAL (web + api + postgres). Em produção,
# o app roda no Dokploy com um Postgres GERENCIADO (recurso separado): lá a
# DATABASE_URL aponta para o hostname do serviço de banco do Dokploy, não para
# "postgres" deste compose.

# Senha do usuário PostgreSQL (usada pelo serviço postgres no docker-compose)
DB_PASSWORD=troque-por-uma-senha-segura

# URL completa de conexão para a API Fastify.
# Em produção com docker-compose, use o hostname "postgres" (nome do serviço).
# A senha deve ser a mesma definida em DB_PASSWORD acima.
DATABASE_URL=postgresql://powerlifting:troque-por-uma-senha-segura@postgres:5432/powerlifting

# ─── Autenticação JWT ─────────────────────────────────────────────────────────

# Segredo usado para assinar os JWT (HS256). Use uma string longa e aleatória (>= 32 caracteres).
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-com-32-chars

# Tempo de expiração do access token (ex.: 15m, 1h)
JWT_EXPIRES_IN=15m

# Tempo de expiração do refresh token (ex.: 7d, 30d)
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────

# Origem permitida pelo CORS da API (URL do frontend)
CORS_ORIGIN=http://localhost:80

# ─── Google OAuth ────────────────────────────────────────────────────────────────────────────

# Client ID do projeto no Google Cloud Console (APIs & Services → Credentials).
# Obrigatório para habilitar o botão "Entrar com Google".
# Configure as origens autorizadas para a URL do frontend e do backend.
# Deixe vazio para desabilitar o login com Google.
GOOGLE_CLIENT_ID=
